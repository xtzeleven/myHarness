# plugin/.env.example
#
# 本文件随 plugin 分发，列出 plugin 内置 MCP server 需要的环境变量。
# 用户使用本 plugin 时，须在自己项目根复制为 .env 并填值：
#     cp ${CLAUDE_PLUGIN_ROOT}/.env.example ./.env
#
# 这些变量被 plugin/.mcp.json 引用。.env 不存在时 MCP server 启动会失败，
# 但 plugin 自身的 hooks / agents / commands 仍可正常工作（degraded mode）。

# MySQL 只读连接（用于 mcp-server-mysql / schema-analyst agent）
# 数据库账号必须只有 SELECT 权限。强制 readonly。
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_RO_USER=
MYSQL_RO_PASS=
MYSQL_DB=
